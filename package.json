{
  "name": "cartridge-system",
  "displayName": "記憶卡匣監控系統",
  "version": "5.3.4",
  "description": "記憶卡匣動態熱處理外掛 — 主動式檔案監聽與記憶過期防禦系統",
  "publisher": "cartridge-system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kunshao1117/cartridge_system.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/logo.png",
  "files": [
    "dist/*.js",
    "assets/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "activationEvents": [
    "workspaceContains:.agents",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "cartridge-system": "dist/mcp-server.js",
    "cartridge-mcp": "dist/mcp-server.js"
  },
  "contributes": {
    "configuration": {
      "title": "Cartridge",
      "properties": {
        "cartridge.updateCheck.enabled": {
          "type": "boolean",
          "scope": "window",
          "default": true,
          "description": "啟用或停用 Cartridge System 啟動時的 GitHub Release 更新檢查。手動檢查命令不受此設定影響。"
        }
      }
    },
    "commands": [
      {
        "command": "cartridge.scan",
        "title": "記憶卡匣：重新掃描索引"
      },
      {
        "command": "cartridge.status",
        "title": "記憶卡匣：查看健康報告"
      },
      {
        "command": "cartridge.scanGhosts",
        "title": "記憶卡匣：重新掃描未歸屬檔案"
      },
      {
        "command": "cartridge.attributeFile",
        "title": "記憶卡匣：歸屬到記憶卡…"
      },
      {
        "command": "cartridge.showGhostFileInfo",
        "title": "記憶卡匣：查看幽靈詳情"
      },
      {
        "command": "cartridge.openGovernanceDashboard",
        "title": "Cartridge：開啟治理總覽"
      },
      {
        "command": "cartridge.openCabinetWorkbench",
        "title": "Cartridge：開啟卡匣機櫃"
      },
      {
        "command": "cartridge.refreshGovernance",
        "title": "Cartridge：重新整理治理側邊欄"
      },
      {
        "command": "cartridge.contextAudit",
        "title": "Cartridge：查看上下文治理報告"
      },
      {
        "command": "cartridge.checkForUpdates",
        "title": "Cartridge：檢查插件更新"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cartridgeGovernance",
          "title": "Cartridge",
          "icon": "assets/cartridge-activity.svg"
        }
      ]
    },
    "views": {
      "cartridgeGovernance": [
        {
          "id": "cartridgeGovernanceOverview",
          "name": "治理總覽",
          "icon": "$(dashboard)",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "cartridgeExplorer",
          "name": "記憶卡匣",
          "icon": "$(server)",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "cartridgeContextExplorer",
          "name": "上下文治理",
          "icon": "$(symbol-event)",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "cartridgeActionItems",
          "name": "待處理項目",
          "icon": "$(warning)",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cartridge.openCabinetWorkbench",
          "group": "navigation@0",
          "when": "view == cartridgeGovernanceOverview"
        },
        {
          "command": "cartridge.openCabinetWorkbench",
          "group": "navigation@0",
          "when": "view == cartridgeExplorer"
        }
      ],
      "explorer/context": [
        {
          "command": "cartridge.attributeFile",
          "group": "cartridge@1",
          "when": "!explorerResourceIsFolder"
        }
      ]
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src/",
    "package": "node scripts/package-vsix.mjs",
    "prepublishOnly": "npm run lint && npm test && npm run build && npx tsc --noEmit && npm pack --dry-run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "cytoscape": "^3.33.3",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5"
  }
}
