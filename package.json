{
  "name": "cartridge-system",
  "displayName": "記憶卡匣監控系統",
  "version": "4.1.0",
  "description": "記憶卡匣動態熱處理外掛 — 主動式檔案監聽與記憶過期防禦系統",
  "publisher": "cartridge-system",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kunshao1117/cartridge_system.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/logo.png",
  "activationEvents": [
    "workspaceContains:.agents",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cartridge.scan",
        "title": "記憶卡匣：重新掃描索引"
      },
      {
        "command": "cartridge.status",
        "title": "記憶卡匣：查看健康報告"
      },
      {
        "command": "cartridge.scanGhosts",
        "title": "記憶卡匣：重新掃描未歸屬檔案"
      },
      {
        "command": "cartridge.attributeFile",
        "title": "記憶卡匣：歸屬到記憶卡…"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "cartridgeExplorer",
          "name": "記憶卡匣",
          "icon": "$(server)",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "cartridge.attributeFile",
          "group": "cartridge@1",
          "when": "!explorerResourceIsFolder"
        }
      ]
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint src/",
    "package": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5"
  }
}
